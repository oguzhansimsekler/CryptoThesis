@page "/"
@using CryptoLibrary
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Cryptography
@using System.Text.Json
@implements IAsyncDisposable

<style>
    .main-container {
        height: 100vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background-color: #f4f7f6;
    }

    .content-row {
        flex: 1;
        overflow: hidden;
    }

    .wire-scroll {
        height: calc(100vh - 240px);
        overflow-y: auto;
        background-color: #000;
        padding: 10px;
        border-radius: 4px;
    }

    .packet-box {
        font-size: 0.8rem;
        background-color: #1a1a1a !important;
        margin-bottom: 10px;
        border: 1px solid #333;
    }

    .x-small {
        font-size: 0.7rem;
        color: #888;
    }

    .stepper-bar {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 10px;
    }

    .step-card {
        border-radius: 10px;
        padding: 10px;
        border: 1px solid #ced4da;
        background: #fff;
        min-height: 68px;
    }

    .step-card.active {
        border-color: #0d6efd;
        background: #e8f1ff;
    }

    .step-card.done {
        border-color: #198754;
        background: #eaf7ef;
    }

    .step-card.error {
        border-color: #dc3545;
        background: #fdecec;
    }

    .step-title {
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
    }

    .step-desc {
        font-size: 0.75rem;
        margin-top: 4px;
    }
</style>

<div class="main-container container-fluid">
    <div class="row p-2 bg-dark text-white align-items-center" style="height: 60px;">
        <div class="col-md-4"><h5>CryptoThesis Lab</h5></div>
        <div class="col-md-8 text-end">
            <div class="btn-group btn-group-sm shadow-sm">
                <button class="btn @(CurrentMode == AppMode.Education ? "btn-primary" : "btn-outline-light")" @onclick="() => SetMode(AppMode.Education)">Egitim</button>
                <button class="btn @(CurrentMode == AppMode.Hacker ? "btn-danger" : "btn-outline-light")" @onclick="() => SetMode(AppMode.Hacker)">Hacker</button>
            </div>
        </div>
    </div>

    <div class="row px-3 pt-3">
        <div class="col-12">
            <div class="stepper-bar">
                @foreach (var step in StepperSteps)
                {
                    <div class="step-card @GetStepCss(step.Key)">
                        <div class="step-title">@step.Title</div>
                        <div class="step-desc">@step.Description</div>
                    </div>
                }
            </div>
        </div>
    </div>

    <div class="row content-row g-0 mt-2">
        <div class="col-md-3 bg-white border-end p-3 shadow-sm">
            <h6 class="text-primary fw-bold mb-3">Alice (Client)</h6>
            <div class="alert @(IsConnected ? "alert-success" : "alert-info") py-2 small mb-3">@AliceStatus</div>
            <div class="d-grid gap-2 mb-3">
                <button class="btn btn-success btn-sm shadow-sm" @onclick="StartHandshake" disabled="@IsHandshakeActive">Handshake Baslat</button>
                <button class="btn btn-outline-secondary btn-sm shadow-sm" @onclick="ResetLab">Yeniden Basla</button>
            </div>
            <hr />
            <div class="small text-muted mb-2">Attack Guide</div>
            <div class="small mb-3">
                <div>`ClientHello`: invalid public key, drop</div>
                <div>`ServerHello`: signature tamper, pinned key mismatch, drop</div>
                <div>`Data`: tag tamper, out-of-order, replay, drop, forged injection</div>
            </div>
            <input type="text" class="form-control form-control-sm mb-2" placeholder="Guvenli mesaj..." @bind="PlainTextMsg" disabled="@(!IsConnected)" />
            <button class="btn btn-primary btn-sm w-100 shadow-sm" @onclick="SendMessage" disabled="@(!IsConnected)">Sifrele ve Gonder</button>
        </div>

        <div class="col-md-6 p-3 d-flex flex-column" style="background-color: #111;">
            <h6 class="text-danger border-bottom border-danger pb-2 mb-3">The Wire (Insecure)</h6>
            <div class="wire-scroll">
                @foreach (var pkg in NetworkLog)
                {
                    <div class="packet-box border @(pkg.IsTampered ? "border-danger" : "border-success") p-2 rounded shadow-sm">
                        <div class="d-flex justify-content-between text-success fw-bold small">
                            <span>#@pkg.SeqNum: @pkg.Type</span>
                            <span class="text-muted x-small">@pkg.Size bytes</span>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(pkg.AttackLabel))
                        {
                            <div class="badge @(pkg.IsTampered ? "bg-warning text-dark" : "bg-success") mb-2">@pkg.AttackLabel</div>
                        }

                        <div class="text-light x-small text-break my-1" style="font-family: 'Courier New', Courier, monospace;">@pkg.JsonContent</div>

                        @if (CurrentMode == AppMode.Hacker && !pkg.IsProcessed)
                        {
                            <div class="mt-2 btn-group w-100">
                                <button class="btn btn-xs btn-success py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => ForwardPacket(pkg))">Ilet</button>

                                @if (pkg.Type == "ClientHello")
                                {
                                    <button class="btn btn-xs btn-danger py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.InvalidClientKey))">Public Key Boz</button>
                                    <button class="btn btn-xs btn-outline-warning py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.Drop))">Dusur</button>
                                }
                                else if (pkg.Type == "ServerHello")
                                {
                                    <button class="btn btn-xs btn-danger py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.SignatureTamper))">Imzayi Boz</button>
                                    <button class="btn btn-xs btn-warning py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.PinnedKeyMismatch))">Pinned Key Boz</button>
                                    <button class="btn btn-xs btn-outline-warning py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.Drop))">Dusur</button>
                                }
                                else if (pkg.Type == "Data")
                                {
                                    <button class="btn btn-xs btn-danger py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.TagTamper))">Tag Boz</button>
                                    <button class="btn btn-xs btn-warning py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.OutOfOrder))">Sira Boz</button>
                                    <button class="btn btn-xs btn-secondary py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.Replay))">Replay</button>
                                    <button class="btn btn-xs btn-outline-warning py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.Drop))">Dusur</button>
                                    <button class="btn btn-xs btn-outline-danger py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => AttackAndForward(pkg, AttackAction.InjectUnknownSession))">Sahte Paket</button>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-md-3 bg-white border-start p-3 shadow-sm">
            <h6 class="text-success fw-bold mb-3">Bob (Server)</h6>
            <div class="alert alert-info py-2 small mb-3">@BobStatus</div>

            <div class="small text-muted mb-2">Security Events</div>
            <div class="mb-3" style="max-height: 140px; overflow-y: auto;">
                @foreach (var evt in SecurityEvents)
                {
                    <div class="border rounded px-2 py-1 mb-1 small @(evt.IsError ? "bg-light border-danger text-danger" : "bg-light border-success text-success")">@evt.Content</div>
                }
            </div>

            <div style="flex: 1; overflow-y: auto;">
                @foreach (var msg in BobMessages)
                {
                    <div class="alert @(msg.IsError ? "alert-danger" : "alert-success") py-1 px-2 mb-2 small shadow-sm border-0">
                        @msg.Content
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private readonly List<ProtocolStep> StepperSteps = new()
    {
        new("clienthello", "ClientHello", "Alice ephemeral key ve nonce gonderir"),
        new("serverhello", "ServerHello", "Bob imzali yanit ve kimlik anahtarini gonderir"),
        new("verify", "Verify", "Alice imzayi ve pinned key eslesmesini dogrular"),
        new("derive", "Key Derivation", "Iki uc da ECDH + HKDF ile session key turetir"),
        new("data", "Secure Data", "AES-GCM ile veri iletilir ve kontrol edilir")
    };

    private CryptoProtocolSession? AliceSession;
    private HubConnection? hubConnection;
    private byte[]? TrustedServerPublicKey;
    private Guid _currentSessionId;
    private byte[] _lastAliceNonce = Array.Empty<byte>();

    private List<NetworkPacket> NetworkLog = new();
    private List<BobMessage> BobMessages = new();
    private List<SecurityEvent> SecurityEvents = new();
    private AppMode CurrentMode = AppMode.Education;
    private string AliceStatus = "Hazir";
    private string BobStatus = "Beklemede";
    private bool IsConnected;
    private bool IsHandshakeActive;
    private string PlainTextMsg = "";
    private string CurrentStep = "clienthello";
    private string? FailedStep;

    protected override async Task OnInitializedAsync()
    {
        TrustedServerPublicKey = ProtocolIdentity.GetPinnedServerPublicKey();

        hubConnection = new HubConnectionBuilder()
            .WithUrl("https://localhost:7214/cryptohub")
            .Build();

        hubConnection.On<string, string, bool>("ReceiveHandshakePackage", async (type, json, isTampered) =>
        {
            LogPacket(type, json, isTampered);

            if (type == "ClientHello")
            {
                CurrentStep = "serverhello";
            }
            else if (type == "ServerHello")
            {
                CurrentStep = "verify";
            }

            if (CurrentMode == AppMode.Education)
            {
                NetworkPacket lastPkg = NetworkLog.Last();
                await ForwardPacket(lastPkg);
            }

            StateHasChanged();
        });

        hubConnection.On<string>("FinalizeServerHello", json =>
        {
            ProcessServerHello(json);
            StateHasChanged();
        });

        hubConnection.On<string, string>("UpdateHandshakeUI", (step, msg) =>
        {
            BobStatus = msg;
            SecurityEvents.Insert(0, new SecurityEvent { Content = msg, IsError = step == "error" });

            if (step == "error")
            {
                FailedStep ??= CurrentStep;
                BobMessages.Insert(0, new BobMessage { Content = $"Kritik guvenlik uyarisi: {msg}", IsError = true });
            }

            StateHasChanged();
        });

        hubConnection.On<DeliveryReport>("ReceiveDeliveryReport", report =>
        {
            ProcessDeliveryReport(report);
            StateHasChanged();
        });

        await hubConnection.StartAsync();
    }

    private async Task ForwardPacket(NetworkPacket pkg)
    {
        if (pkg.IsProcessed)
        {
            return;
        }

        pkg.IsProcessed = true;
        pkg.AttackLabel = "Normal";

        if (pkg.Type == "ClientHello")
        {
            await hubConnection!.SendAsync("BobProcessClientHello", pkg.JsonContent, "None");
        }
        else if (pkg.Type == "ServerHello")
        {
            await hubConnection!.SendAsync("ForwardToAlice", pkg.JsonContent, "None");
        }
        else if (pkg.Type == "Data")
        {
            CurrentStep = "data";
            await hubConnection!.SendAsync("RelayMessage", _currentSessionId, pkg.JsonContent, "None");
        }
    }

    private async Task AttackAndForward(NetworkPacket pkg, AttackAction attack)
    {
        if (pkg.IsProcessed)
        {
            return;
        }

        pkg.IsProcessed = true;
        pkg.IsTampered = true;
        pkg.AttackLabel = GetAttackLabel(attack);
        SecurityEvents.Insert(0, new SecurityEvent { Content = $"Attack injected: {pkg.AttackLabel}", IsError = true });

        if (attack == AttackAction.Drop)
        {
            FailedStep ??= GetFailureStepForPacket(pkg.Type);
            BobStatus = "Paket ag uzerinde baskilandi.";
            AliceStatus = "Iletim saldirgan tarafindan engellendi.";
            return;
        }

        if (pkg.Type == "ClientHello" && attack == AttackAction.InvalidClientKey)
        {
            FailedStep = "serverhello";
            await hubConnection!.SendAsync("BobProcessClientHello", pkg.JsonContent, "InvalidClientKey");
            return;
        }

        if (pkg.Type == "ServerHello")
        {
            FailedStep = "verify";
            string mode = attack == AttackAction.PinnedKeyMismatch ? "PinnedKeyMismatch" : "SignatureTamper";
            await hubConnection!.SendAsync("ForwardToAlice", pkg.JsonContent, mode);
            return;
        }

        if (pkg.Type == "Data" && attack == AttackAction.Replay)
        {
            CurrentStep = "data";
            await hubConnection!.SendAsync("RelayMessage", _currentSessionId, pkg.JsonContent, "None");
            LogPacket("Data", pkg.JsonContent, true, "Replay copy");
            NetworkLog.Last().IsProcessed = true;
            FailedStep = "data";
            await hubConnection!.SendAsync("RelayMessage", _currentSessionId, pkg.JsonContent, "None");
            return;
        }

        if (pkg.Type == "Data" && attack == AttackAction.InjectUnknownSession)
        {
            CurrentStep = "data";
            FailedStep = "data";
            await hubConnection!.SendAsync("RelayMessage", Guid.NewGuid(), pkg.JsonContent, "None");
            return;
        }

        if (pkg.Type == "Data")
        {
            CurrentStep = "data";
            FailedStep = "data";
            string mode = attack == AttackAction.OutOfOrder ? "OutOfOrder" : "TagTamper";
            await hubConnection!.SendAsync("RelayMessage", _currentSessionId, pkg.JsonContent, mode);
        }
    }

    private void ProcessServerHello(string json)
    {
        ServerHelloMessage? hello = JsonSerializer.Deserialize<ServerHelloMessage>(json);
        if (hello == null || AliceSession == null || TrustedServerPublicKey == null)
        {
            return;
        }

        AliceStatus = "ServerHello dogrulaniyor...";
        CurrentStep = "verify";

        if (!TrustedServerPublicKey.SequenceEqual(hello.ServerIdentityPublicKey))
        {
            AliceStatus = "Server kimligi pinli anahtarla eslesmedi.";
            SecurityEvents.Insert(0, new SecurityEvent { Content = "Pinned key mismatch detected on client.", IsError = true });
            FailedStep = "verify";
            IsHandshakeActive = false;
            return;
        }

        byte[] transcript = ProtocolHelpers.BuildHandshakeTranscript(
            _lastAliceNonce,
            hello.ServerNonce,
            AliceSession.MyEphemeralPub!,
            hello.ServerEphemeralPublicKey,
            hello.ServerIdentityPublicKey);

        bool isValid = AliceSession.Identity.VerifySignature(transcript, hello.Signature);

        if (!isValid)
        {
            AliceStatus = "Imza hatasi. Mudahale saptandi.";
            BobStatus = "Bob tarafina ulasmadan paket reddedildi.";
            SecurityEvents.Insert(0, new SecurityEvent { Content = "Ed25519 signature verification failed.", IsError = true });
            FailedStep = "verify";
            IsHandshakeActive = false;
            return;
        }

        CurrentStep = "derive";
        AliceSession.FinalizeHandshake(
            hello.ServerIdentityPublicKey,
            hello.ServerEphemeralPublicKey,
            _lastAliceNonce,
            hello.ServerNonce);

        AliceStatus = "Guvenli tunel aktif";
        BobStatus = "Oturum anahtari iki ucta da turetildi.";
        SecurityEvents.Insert(0, new SecurityEvent { Content = "Handshake completed and session key derived.", IsError = false });
        CurrentStep = "data";
        FailedStep = null;
        IsConnected = true;
        IsHandshakeActive = false;
    }

    private void ProcessDeliveryReport(DeliveryReport report)
    {
        CurrentStep = "data";

        if (report.Success)
        {
            BobMessages.Insert(0, new BobMessage { Content = report.StatusMessage, IsError = false });
            BobStatus = "Veri dogrulandi ve cozuldu";
            SecurityEvents.Insert(0, new SecurityEvent { Content = report.StatusMessage, IsError = false });
        }
        else
        {
            BobMessages.Insert(0, new BobMessage { Content = report.StatusMessage, IsError = true });
            BobStatus = "Paket reddedildi";
            SecurityEvents.Insert(0, new SecurityEvent { Content = report.StatusMessage, IsError = true });
            FailedStep ??= "data";
        }
    }

    private async Task StartHandshake()
    {
        ResetLab();
        IsHandshakeActive = true;
        AliceStatus = "ClientHello hazirlaniyor...";

        _currentSessionId = Guid.NewGuid();
        _lastAliceNonce = RandomNumberGenerator.GetBytes(16);
        AliceSession = new CryptoProtocolSession(new IdentityService(TrustedServerPublicKey!), "Client");

        var clientHello = new ClientHelloMessage
        {
            SessionId = _currentSessionId,
            ClientNonce = _lastAliceNonce,
            ClientEphemeralPublicKey = AliceSession.MyEphemeralPub!
        };

        await hubConnection!.SendAsync("PostClientHello", clientHello);
    }

    private void ResetLab()
    {
        IsHandshakeActive = false;
        IsConnected = false;
        AliceSession = null;
        _currentSessionId = Guid.Empty;
        _lastAliceNonce = Array.Empty<byte>();
        PlainTextMsg = string.Empty;
        NetworkLog.Clear();
        BobMessages.Clear();
        SecurityEvents.Clear();
        AliceStatus = "Hazir";
        BobStatus = "Beklemede";
        CurrentStep = "clienthello";
        FailedStep = null;
        StateHasChanged();
    }

    private async Task SendMessage()
    {
        if (AliceSession?.Channel == null || string.IsNullOrWhiteSpace(PlainTextMsg))
        {
            return;
        }

        SecurePackage package = AliceSession.Channel.Encrypt(PlainTextMsg);
        string json = JsonSerializer.Serialize(package);
        LogPacket("Data", json, false);

        if (CurrentMode == AppMode.Education)
        {
            await ForwardPacket(NetworkLog.Last());
        }

        PlainTextMsg = string.Empty;
    }

    private void LogPacket(string type, string json, bool tampered, string attackLabel = "")
    {
        NetworkLog.Add(new NetworkPacket
        {
            Type = type,
            JsonContent = json,
            Size = json.Length,
            SeqNum = NetworkLog.Count + 1,
            IsTampered = tampered,
            IsProcessed = false,
            AttackLabel = attackLabel
        });
    }

    private string GetStepCss(string key)
    {
        if (FailedStep == key)
        {
            return "error";
        }

        int currentIndex = StepperSteps.FindIndex(x => x.Key == CurrentStep);
        int stepIndex = StepperSteps.FindIndex(x => x.Key == key);

        if (stepIndex < currentIndex)
        {
            return "done";
        }

        if (stepIndex == currentIndex)
        {
            return "active";
        }

        return string.Empty;
    }

    private static string GetAttackLabel(AttackAction attack) => attack switch
    {
        AttackAction.InvalidClientKey => "Invalid Public Key",
        AttackAction.SignatureTamper => "Signature Tamper",
        AttackAction.PinnedKeyMismatch => "Pinned Key Mismatch",
        AttackAction.TagTamper => "Tag Tamper",
        AttackAction.OutOfOrder => "Out-of-Order",
        AttackAction.Replay => "Replay Attack",
        AttackAction.Drop => "Dropped Packet",
        AttackAction.InjectUnknownSession => "Forged Injection",
        _ => "Normal"
    };

    private static string GetFailureStepForPacket(string packetType) => packetType switch
    {
        "ClientHello" => "serverhello",
        "ServerHello" => "verify",
        _ => "data"
    };

    private void SetMode(AppMode mode) => CurrentMode = mode;

    public enum AppMode
    {
        Education,
        Hacker
    }

    public enum AttackAction
    {
        InvalidClientKey,
        SignatureTamper,
        PinnedKeyMismatch,
        TagTamper,
        OutOfOrder,
        Replay,
        Drop,
        InjectUnknownSession
    }

    public record ProtocolStep(string Key, string Title, string Description);

    public class NetworkPacket
    {
        public string Type { get; set; } = "";
        public string JsonContent { get; set; } = "";
        public int Size { get; set; }
        public int SeqNum { get; set; }
        public bool IsTampered { get; set; }
        public bool IsProcessed { get; set; }
        public string AttackLabel { get; set; } = "";
    }

    public class BobMessage
    {
        public string Content { get; set; } = "";
        public bool IsError { get; set; }
    }

    public class SecurityEvent
    {
        public string Content { get; set; } = "";
        public bool IsError { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
