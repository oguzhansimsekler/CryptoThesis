@page "/"
@using CryptoLibrary
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Cryptography
@using System.Text.Json
@implements IAsyncDisposable

<style>
    .main-container {
        height: 100vh;
        overflow: hidden;
        display: flex;
        flex-direction: column;
        background-color: #f4f7f6;
    }

    .content-row {
        flex: 1;
        overflow: hidden;
    }

    .wire-scroll {
        height: calc(100vh - 180px);
        overflow-y: auto;
        background-color: #000;
        padding: 10px;
        border-radius: 4px;
    }

    .packet-box {
        font-size: 0.8rem;
        background-color: #1a1a1a !important;
        margin-bottom: 10px;
        border: 1px solid #333;
    }

    .x-small {
        font-size: 0.7rem;
        color: #888;
    }
</style>

<div class="main-container container-fluid">
    <div class="row p-2 bg-dark text-white align-items-center" style="height: 60px;">
        <div class="col-md-4"><h5>CryptoThesis Lab</h5></div>
        <div class="col-md-8 text-end">
            <div class="btn-group btn-group-sm shadow-sm">
                <button class="btn @(CurrentMode == AppMode.Education ? "btn-primary" : "btn-outline-light")" @onclick="() => SetMode(AppMode.Education)">Egitim</button>
                <button class="btn @(CurrentMode == AppMode.Hacker ? "btn-danger" : "btn-outline-light")" @onclick="() => SetMode(AppMode.Hacker)">Hacker</button>
            </div>
        </div>
    </div>

    <div class="row content-row g-0">
        <div class="col-md-3 bg-white border-end p-3 shadow-sm">
            <h6 class="text-primary fw-bold mb-3">Alice (Client)</h6>
            <div class="alert @(IsConnected ? "alert-success" : "alert-info") py-2 small mb-3">@AliceStatus</div>
            <button class="btn btn-success btn-sm w-100 mb-3 shadow-sm" @onclick="StartHandshake" disabled="@IsHandshakeActive">Handshake Baslat</button>
            <hr />
            <input type="text" class="form-control form-control-sm mb-2" placeholder="Guvenli mesaj..." @bind="PlainTextMsg" disabled="@(!IsConnected)" />
            <button class="btn btn-primary btn-sm w-100 shadow-sm" @onclick="SendMessage" disabled="@(!IsConnected)">Sifrele ve Gonder</button>
        </div>

        <div class="col-md-6 p-3 d-flex flex-column" style="background-color: #111;">
            <h6 class="text-danger border-bottom border-danger pb-2 mb-3">The Wire (Insecure)</h6>
            <div class="wire-scroll">
                @foreach (var pkg in NetworkLog)
                {
                    <div class="packet-box border @(pkg.IsTampered ? "border-danger" : "border-success") p-2 rounded shadow-sm">
                        <div class="d-flex justify-content-between text-success fw-bold small">
                            <span>#@pkg.SeqNum: @pkg.Type</span>
                            <span class="text-muted x-small">@pkg.Size bytes</span>
                        </div>
                        <div class="text-light x-small text-break my-1" style="font-family: 'Courier New', Courier, monospace;">@pkg.JsonContent</div>

                        @if (CurrentMode == AppMode.Hacker && !pkg.IsProcessed)
                        {
                            <div class="mt-2 btn-group w-100">
                                <button class="btn btn-xs btn-success py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => ForwardPacket(pkg))">Ilet</button>
                                <button class="btn btn-xs btn-danger py-1 fw-bold" style="font-size: 0.7rem;" @onclick="@(() => TamperAndForward(pkg))">Boz ve Ilet</button>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="col-md-3 bg-white border-start p-3 shadow-sm">
            <h6 class="text-success fw-bold mb-3">Bob (Server)</h6>
            <div class="alert alert-info py-2 small mb-3">@BobStatus</div>
            <div style="flex: 1; overflow-y: auto;">
                @foreach (var msg in BobMessages)
                {
                    <div class="alert @(msg.IsError ? "alert-danger" : "alert-success") py-1 px-2 mb-2 small shadow-sm border-0">
                        @msg.Content
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private CryptoProtocolSession? AliceSession;
    private HubConnection? hubConnection;
    private byte[]? TrustedServerPublicKey;
    private Guid _currentSessionId;
    private byte[] _lastAliceNonce = Array.Empty<byte>();

    private List<NetworkPacket> NetworkLog = new();
    private List<BobMessage> BobMessages = new();
    private AppMode CurrentMode = AppMode.Education;
    private string AliceStatus = "Hazir";
    private string BobStatus = "Beklemede";
    private bool IsConnected;
    private bool IsHandshakeActive;
    private string PlainTextMsg = "";

    protected override async Task OnInitializedAsync()
    {
        TrustedServerPublicKey = ProtocolIdentity.GetPinnedServerPublicKey();

        hubConnection = new HubConnectionBuilder()
            .WithUrl("https://localhost:7214/cryptohub")
            .Build();

        hubConnection.On<string, string, bool>("ReceiveHandshakePackage", async (type, json, isTampered) =>
        {
            LogPacket(type, json, isTampered);

            if (CurrentMode == AppMode.Education)
            {
                NetworkPacket lastPkg = NetworkLog.Last();
                await ForwardPacket(lastPkg);
            }

            StateHasChanged();
        });

        hubConnection.On<string>("FinalizeServerHello", json =>
        {
            ProcessServerHello(json);
            StateHasChanged();
        });

        hubConnection.On<string, string>("UpdateHandshakeUI", (step, msg) =>
        {
            BobStatus = msg;
            if (step == "error")
            {
                BobMessages.Insert(0, new BobMessage { Content = $"Kritik guvenlik uyarisi: {msg}", IsError = true });
            }

            StateHasChanged();
        });

        hubConnection.On<DeliveryReport>("ReceiveDeliveryReport", report =>
        {
            ProcessDeliveryReport(report);
            StateHasChanged();
        });

        await hubConnection.StartAsync();
    }

    private async Task ForwardPacket(NetworkPacket pkg)
    {
        if (pkg.IsProcessed)
        {
            return;
        }

        pkg.IsProcessed = true;

        if (pkg.Type == "ClientHello")
        {
            await hubConnection!.SendAsync("BobProcessClientHello", pkg.JsonContent, pkg.IsTampered);
        }
        else if (pkg.Type == "ServerHello")
        {
            await hubConnection!.SendAsync("ForwardToAlice", pkg.JsonContent, pkg.IsTampered);
        }
        else if (pkg.Type == "Data")
        {
            await hubConnection!.SendAsync("RelayMessage", _currentSessionId, pkg.JsonContent, pkg.IsTampered);
        }
    }

    private async Task TamperAndForward(NetworkPacket pkg)
    {
        if (pkg.IsProcessed)
        {
            return;
        }

        pkg.IsTampered = true;
        await ForwardPacket(pkg);
    }

    private void ProcessServerHello(string json)
    {
        ServerHelloMessage? hello = JsonSerializer.Deserialize<ServerHelloMessage>(json);
        if (hello == null || AliceSession == null || TrustedServerPublicKey == null)
        {
            return;
        }

        AliceStatus = "ServerHello dogrulaniyor...";

        if (!TrustedServerPublicKey.SequenceEqual(hello.ServerIdentityPublicKey))
        {
            AliceStatus = "Server kimligi pinli anahtarla eslesmedi.";
            IsHandshakeActive = false;
            return;
        }

        byte[] transcript = ProtocolHelpers.BuildHandshakeTranscript(
            _lastAliceNonce,
            hello.ServerNonce,
            AliceSession.MyEphemeralPub!,
            hello.ServerEphemeralPublicKey,
            hello.ServerIdentityPublicKey);

        bool isValid = AliceSession.Identity.VerifySignature(transcript, hello.Signature);

        if (!isValid)
        {
            AliceStatus = "Imza hatasi. Müdahale saptandi.";
            BobStatus = "Bob tarafina ulasmadan paket reddedildi.";
            IsHandshakeActive = false;
            return;
        }

        AliceSession.FinalizeHandshake(
            hello.ServerIdentityPublicKey,
            hello.ServerEphemeralPublicKey,
            _lastAliceNonce,
            hello.ServerNonce);

        AliceStatus = "Guvenli tunel aktif";
        BobStatus = "Oturum anahtari iki ucta da turetildi.";
        IsConnected = true;
        IsHandshakeActive = false;
    }

    private void ProcessDeliveryReport(DeliveryReport report)
    {
        if (report.Success)
        {
            BobMessages.Insert(0, new BobMessage { Content = report.StatusMessage, IsError = false });
            BobStatus = "Veri dogrulandi ve cozuldu";
        }
        else
        {
            BobMessages.Insert(0, new BobMessage { Content = report.StatusMessage, IsError = true });
            BobStatus = "Paket reddedildi";
        }
    }

    private async Task StartHandshake()
    {
        IsHandshakeActive = true;
        IsConnected = false;
        NetworkLog.Clear();
        BobMessages.Clear();
        AliceStatus = "ClientHello hazirlaniyor...";
        BobStatus = "Beklemede";

        _currentSessionId = Guid.NewGuid();
        _lastAliceNonce = RandomNumberGenerator.GetBytes(16);
        AliceSession = new CryptoProtocolSession(new IdentityService(TrustedServerPublicKey!), "Client");

        var clientHello = new ClientHelloMessage
        {
            SessionId = _currentSessionId,
            ClientNonce = _lastAliceNonce,
            ClientEphemeralPublicKey = AliceSession.MyEphemeralPub!
        };

        await hubConnection!.SendAsync("PostClientHello", clientHello);
    }

    private async Task SendMessage()
    {
        if (AliceSession?.Channel == null || string.IsNullOrWhiteSpace(PlainTextMsg))
        {
            return;
        }

        SecurePackage package = AliceSession.Channel.Encrypt(PlainTextMsg);
        string json = JsonSerializer.Serialize(package);
        LogPacket("Data", json, false);

        if (CurrentMode == AppMode.Education)
        {
            await ForwardPacket(NetworkLog.Last());
        }

        PlainTextMsg = string.Empty;
    }

    private void LogPacket(string type, string json, bool tampered)
    {
        NetworkLog.Add(new NetworkPacket
        {
            Type = type,
            JsonContent = json,
            Size = json.Length,
            SeqNum = NetworkLog.Count + 1,
            IsTampered = tampered,
            IsProcessed = false
        });
    }

    private void SetMode(AppMode mode) => CurrentMode = mode;

    public enum AppMode
    {
        Education,
        Hacker
    }

    public class NetworkPacket
    {
        public string Type { get; set; } = "";
        public string JsonContent { get; set; } = "";
        public int Size { get; set; }
        public int SeqNum { get; set; }
        public bool IsTampered { get; set; }
        public bool IsProcessed { get; set; }
    }

    public class BobMessage
    {
        public string Content { get; set; } = "";
        public bool IsError { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (hubConnection is not null)
        {
            await hubConnection.DisposeAsync();
        }
    }
}
