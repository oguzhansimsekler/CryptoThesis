@page "/measurements"

<PageTitle>Measurements</PageTitle>

<style>
    .chart-shell {
        border: 1px solid #d7dde5;
        border-radius: 12px;
        background: linear-gradient(180deg, #fbfcfe 0%, #f1f5f9 100%);
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: repeat(5, 1fr);
        gap: 1rem;
        align-items: end;
        min-height: 320px;
        padding-top: 1rem;
        border-bottom: 2px solid #94a3b8;
        border-left: 2px solid #94a3b8;
        position: relative;
    }

    .chart-grid::before {
        content: "";
        position: absolute;
        inset: 0 0 2px 0;
        background-image:
            linear-gradient(to top, rgba(148, 163, 184, 0.25) 1px, transparent 1px);
        background-size: 100% 20%;
        pointer-events: none;
    }

    .chart-col {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: end;
        min-height: 300px;
    }

    .chart-value {
        font-size: 0.8rem;
        font-weight: 700;
        color: #1d4ed8;
        margin-bottom: 0.4rem;
    }

    .chart-bar {
        width: 58px;
        border-radius: 10px 10px 0 0;
        background: linear-gradient(180deg, #60a5fa 0%, #2563eb 100%);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
        min-height: 18px;
    }

    .chart-label {
        margin-top: 0.8rem;
        font-size: 0.75rem;
        font-weight: 600;
        text-align: center;
        color: #334155;
    }

    .chart-note {
        margin-top: 0.75rem;
        font-size: 0.85rem;
        color: #475569;
    }
</style>

<h1>Performance Measurements</h1>

<p>
    Bu sayfa, repo icindeki <code>KriptoMeasurements</code> araci ile uretilen son benchmark degerlerini gosterir.
    Olcumler <code>net7.0</code> ortaminda 50 warmup ve 1000 olcum iterasyonu ile alinmistir.
</p>

<div class="chart-shell">
    <h5 class="mb-3">Latency Comparison (Average ms)</h5>
    <div class="chart-grid">
        @foreach (var row in Rows)
        {
            <div class="chart-col">
                <div class="chart-value">@row.AverageMs</div>
                <div class="chart-bar" style="height:@($"{GetBarHeight(row.AverageValue)}px")"></div>
                <div class="chart-label">@row.ShortLabel</div>
            </div>
        }
    </div>
    <div class="chart-note">
        Grafik, ortalama gecikme degerlerini gosterir. En yuksek gecikme su anda <strong>Complete Secure Handshake</strong>
        operasyonundadir; en dusuk gecikme ise <strong>HKDF Key Derivation</strong> asamasindadir.
    </div>
    <div class="chart-note">
        Not: Kolon yukseklikleri, kucuk gecikme farklarinin da gorulebilmesi icin logaritmik gorsel olcek ile cizilmistir.
        Sayisal degerler sutun ustunde ve tabloda dogrudan verilmis haldedir.
    </div>
</div>

<div class="table-responsive">
    <table class="table table-striped table-bordered align-middle">
        <thead class="table-dark">
            <tr>
                <th>Operation</th>
                <th>Average (ms)</th>
                <th>Median (ms)</th>
                <th>Min (ms)</th>
                <th>Max (ms)</th>
                <th>Notes</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var row in Rows)
            {
                <tr>
                    <td>@row.Operation</td>
                    <td>@row.AverageMs</td>
                    <td>@row.MedianMs</td>
                    <td>@row.MinMs</td>
                    <td>@row.MaxMs</td>
                    <td>@row.Notes</td>
                </tr>
            }
        </tbody>
    </table>
</div>

<div class="alert alert-info mt-3">
    Bu sayilari yeniden uretmek icin terminalde su komutu calistirabilirsiniz:
    <code>dotnet run --project KriptoMeasurements\KriptoMeasurements.csproj --no-restore</code>
</div>

@code {
    private readonly List<MeasurementRow> Rows = new()
    {
        new("X25519 Key Generation", "X25519", 0.0963, "0.0963", "0.0930", "0.0801", "0.3521", "Ephemeral Curve25519 anahtar cifti uretimi"),
        new("HKDF Key Derivation", "HKDF", 0.0103, "0.0103", "0.0089", "0.0079", "0.0561", "Transcript bagli oturum anahtari turetimi"),
        new("AES-256-GCM Encryption (1 KB)", "AES Enc", 0.0233, "0.0233", "0.0221", "0.0195", "0.9977", "1 KB veri sifreleme"),
        new("AES-256-GCM Decryption (1 KB)", "AES Dec", 0.0449, "0.0449", "0.0409", "0.0393", "2.5099", "1 KB veri cozumleme ve tag kontrolu"),
        new("Complete Secure Handshake", "Handshake", 0.3086, "0.3086", "0.2684", "0.1899", "1.4726", "X25519 + Ed25519 + HKDF ile uc-tan-uca oturum kurulumu")
    };

    private double MaxAverageLog => Rows.Max(x => Math.Log10(x.AverageValue + 1));

    private double GetBarHeight(double value)
    {
        const double maxHeight = 230d;
        const double minHeight = 18d;
        double normalized = Math.Log10(value + 1) / MaxAverageLog;
        return minHeight + (normalized * maxHeight);
    }

    private record MeasurementRow(
        string Operation,
        string ShortLabel,
        double AverageValue,
        string AverageMs,
        string MedianMs,
        string MinMs,
        string MaxMs,
        string Notes);
}
