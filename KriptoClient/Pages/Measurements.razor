@page "/measurements"
@using System.Net.Http.Json
@inject HttpClient Http

<PageTitle>Measurements</PageTitle>

<style>
    .chart-shell {
        border: 1px solid #d7dde5;
        border-radius: 12px;
        background: linear-gradient(180deg, #fbfcfe 0%, #f1f5f9 100%);
        padding: 1rem;
        margin-bottom: 1.5rem;
    }

    .chart-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
        gap: 1rem;
        align-items: end;
        min-height: 340px;
        padding-top: 1rem;
        border-bottom: 2px solid #94a3b8;
        border-left: 2px solid #94a3b8;
        position: relative;
    }

    .chart-grid::before {
        content: "";
        position: absolute;
        inset: 0 0 2px 0;
        background-image:
            linear-gradient(to top, rgba(148, 163, 184, 0.25) 1px, transparent 1px);
        background-size: 100% 20%;
        pointer-events: none;
    }

    .chart-col {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: end;
        min-height: 320px;
    }

    .chart-value {
        font-size: 0.8rem;
        font-weight: 700;
        color: #1d4ed8;
        margin-bottom: 0.4rem;
    }

    .chart-bar {
        width: 58px;
        border-radius: 10px 10px 0 0;
        background: linear-gradient(180deg, #60a5fa 0%, #2563eb 100%);
        box-shadow: 0 10px 20px rgba(37, 99, 235, 0.2);
        min-height: 18px;
    }

    .chart-label {
        margin-top: 0.8rem;
        font-size: 0.75rem;
        font-weight: 600;
        text-align: center;
        color: #334155;
    }

    .chart-note {
        margin-top: 0.75rem;
        font-size: 0.85rem;
        color: #475569;
    }
</style>

<h1>Performance Measurements</h1>

@if (_report is null)
{
    <div class="alert alert-secondary">Olcum raporu yukleniyor...</div>
}
else
{
    <p>
        Bu sayfa, repo icindeki <code>KriptoMeasurements</code> araci ile uretilen son benchmark degerlerini gosterir.
        Olcumler <code>net7.0</code> ortaminda @_report.WarmupIterations warmup ve @_report.MeasurementIterations olcum iterasyonu ile alinmistir.
    </p>

    <div class="chart-shell">
        <h5 class="mb-3">Latency Comparison (Average ms)</h5>
        <div class="chart-grid">
            @foreach (var row in _report.Results)
            {
                <div class="chart-col">
                    <div class="chart-value">@row.AverageMs.ToString("F4")</div>
                    <div class="chart-bar" style="height:@($"{GetBarHeight(row.AverageMs)}px")"></div>
                    <div class="chart-label">@GetShortLabel(row.Operation)</div>
                </div>
            }
        </div>
        <div class="chart-note">
            Grafik, ortalama gecikme degerlerini gosterir. En yuksek gecikme ve en dusuk gecikme secilen benchmark setine gore
            dinamik olarak guncellenir.
        </div>
        <div class="chart-note">
            Not: Kolon yukseklikleri, kucuk gecikme farklarinin da gorulebilmesi icin logaritmik gorsel olcek ile cizilmistir.
            Sayisal degerler sutun ustunde ve tabloda dogrudan verilmis haldedir.
        </div>
        <div class="chart-note">
            Rapor olusturma zamani (UTC): <strong>@_report.GeneratedAtUtc.ToString("yyyy-MM-dd HH:mm:ss")</strong>
        </div>
    </div>

    <div class="table-responsive">
        <table class="table table-striped table-bordered align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Operation</th>
                    <th>Average (ms)</th>
                    <th>Median (ms)</th>
                    <th>Min (ms)</th>
                    <th>Max (ms)</th>
                    <th>Notes</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in _report.Results)
                {
                    <tr>
                        <td>@row.Operation</td>
                        <td>@row.AverageMs.ToString("F4")</td>
                        <td>@row.MedianMs.ToString("F4")</td>
                        <td>@row.MinMs.ToString("F4")</td>
                        <td>@row.MaxMs.ToString("F4")</td>
                        <td>@row.Notes</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="alert alert-info mt-3">
        Bu sayilari yeniden uretmek icin terminalde su komutu calistirabilirsiniz:
        <code>dotnet run --project KriptoMeasurements\KriptoMeasurements.csproj --no-restore</code>
    </div>
}

@code {
    private MeasurementReport? _report;

    protected override async Task OnInitializedAsync()
    {
        _report = await Http.GetFromJsonAsync<MeasurementReport>("sample-data/measurements.json");
    }

    private double MaxAverageLog => _report is null || _report.Results.Count == 0
        ? 1d
        : _report.Results.Max(x => Math.Log10(x.AverageMs + 1));

    private double GetBarHeight(double value)
    {
        const double maxHeight = 240d;
        const double minHeight = 18d;
        double normalized = Math.Log10(value + 1) / MaxAverageLog;
        return minHeight + (normalized * maxHeight);
    }

    private static string GetShortLabel(string operation)
    {
        return operation
            .Replace("AES-256-GCM ", "AES ")
            .Replace("Complete Secure ", "")
            .Replace(" (Shared Secret)", "")
            .Replace(" Transcript Hash", " Hash")
            .Replace(" Key Derivation", " HKDF");
    }

    private sealed record MeasurementReport(
        int WarmupIterations,
        int MeasurementIterations,
        DateTime GeneratedAtUtc,
        List<MeasurementRow> Results);

    private sealed record MeasurementRow(
        string Operation,
        string Notes,
        double AverageMs,
        double MedianMs,
        double MinMs,
        double MaxMs);
}
